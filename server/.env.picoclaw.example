# ClawApp - PicoClaw 配置示例
# 复制此文件为 .env 并修改配置

# ========== 代理服务端配置 ==========
PROXY_PORT=3210
PROXY_TOKEN=my-clawapp-token-123

# ========== 后端类型 ==========
# 可选值: openclaw, picoclaw
BACKEND_TYPE=picoclaw

# ========== PicoClaw 配置 ==========
# PicoClaw Gateway 地址（默认端口 18790）
PICOCLAW_GATEWAY_URL=ws://127.0.0.1:18790/pico/ws

# PicoClaw 认证 Token（与 PicoClaw config.json 中的 channels.pico.token 一致）
PICOCLAW_GATEWAY_TOKEN=my-picoclaw-token-456

# ========== 可选配置 ==========
# 媒体文件访问权限（1=允许所有路径，0=仅允许 /tmp/ 和 /var/folders/）
MEDIA_ALLOW_ALL=0

# 额外允许的 CORS 来源（多个用逗号分隔）
# ALLOWED_ORIGINS=https://your-domain.com,https://xxx.trycloudflare.com

# ========== 调试模式 ==========
# 启用详细日志
# DEBUG=1
